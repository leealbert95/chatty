generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoomType {
  dm
  room
}

enum MemberType {
  admin
  member
}

model User {
  userId         String           @id @map("user_id") @db.VarChar(45)
  name           String           @db.VarChar(45)
  email          String           @db.VarChar(45)
  profilePicture String?          @map("profile_picture") @db.VarChar(255)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @default(now()) @map("updated_at")
  credentials    UserCredentials?
  memberships    RoomMembership[]
  messages       Message[]

  @@map("users")
}

model UserCredentials {
  userId    String   @id @map("user_id") @db.VarChar(45)
  password  String   @db.VarChar(60)
  user      User     @relation(fields: [userId], references: [userId])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("user_credentials")
}

model Room {
  roomId      String           @id @map("room_id") @db.VarChar(45)
  name        String           @db.VarChar(45)
  type        RoomType
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @map("updated_at")
  memberships RoomMembership[]
  messages    Message[]

  @@map("rooms")
}

model RoomMembership {
  userId         String     @map("user_id") @db.VarChar(45)
  roomId         String     @map("room_id") @db.VarChar(45)
  membershipType MemberType @default(member) @map("membership_type")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @default(now()) @map("updated_at")
  user           User       @relation(fields: [userId], references: [userId])
  room           Room       @relation(fields: [roomId], references: [roomId])

  @@id([userId, roomId])
  @@map("room_memberships")
}

model Message {
  messageId String   @id @map("message_id") @db.VarChar(45)
  content   String   @db.Text
  roomId    String   @map("room_id") @db.VarChar(45)
  sentBy    String?  @map("sent_by") @db.VarChar(45)
  sentAt    DateTime @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  room      Room     @relation(fields: [roomId], references: [roomId])
  sender    User?    @relation(fields: [sentBy], references: [userId])

  @@map("messages")
}
