{
  "name": "chatty-server",
  "version": "0.0.1",
  "private": true,
  "prisma": {
    "seed": "ts-node --require tsconfig-paths/register -r dotenv/config prisma/seed.ts"
  },
  "scripts": {
    "dev": "lsof -ti:3001 | xargs kill -9 || true && ts-node-dev --require tsconfig-paths/register -r dotenv/config --respawn --transpile-only src/index.ts",
    "dev:debug": "lsof -ti:3001 | xargs kill -9 || true && ts-node-dev --require tsconfig-paths/register -r dotenv/config --respawn --inspect=9229 --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server/src/index.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-session": "^1.18.0",
    "mysql2": "^3.9.1",
    "prisma": "^6.19.3",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.7.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.20",
    "@types/session-file-store": "^1.2.6",
    "@types/uuid": "^9.0.8",
    "csv-parse": "^6.2.1",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.4.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
